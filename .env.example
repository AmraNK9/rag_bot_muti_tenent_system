# Database configuration (PostgreSQL + pgvector)
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/chatbot_saas"

# LLM provider configuration (DeepSeek API)
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Embedding provider configuration (Voyage AI)
VOYAGE_API_KEY="your-voyage-api-key-here"

# Vector Database: pgvector (PostgreSQL extension — no separate server needed)
# Vectors are stored in the knowledge_embeddings table inside the same PostgreSQL DB.
# Ensure pgvector extension is installed: https://github.com/pgvector/pgvector

# Application configuration
NODE_ENV="development"
PORT=3000
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# Telegram Bot token (obtained from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"

# Cloudflare Quick Tunnel — no token or account required!
# The tunnel starts automatically on `npm run dev` via the `cloudflared` npm package.
# URL format: https://<random>.trycloudflare.com

# Keyword Extraction Strategy
# "false" (default): Uses fast local keyword extractor (no API call, ~0ms)
# "true": Uses LLM tool calling via DeepSeek (more accurate, but adds ~1-2s latency)
USE_TOOL_CALLING_EXTRACTION="false"

# Search Mode
# "false" (default): Pure vector search using cosine similarity
# "true": Hybrid search — 70% vector similarity + 30% keyword overlap fusion ranking
USE_HYBRID_SEARCH="false"

# JWT Authentication Secret
# Used for signing Business auth tokens. Change this in production!
JWT_SECRET="your-jwt-secret-change-in-production"

# Debug Logging
# "true": Enables detailed RAG pipeline logging (keywords, vector search, hybrid ranking, etc.)
# "false" (default): Only essential logs
DEBUG_MODE="true"
